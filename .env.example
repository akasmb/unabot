# Environment variables for the Discord bot. Copy this file to .env and fill in the values.
APP_ID= {your Discord application ID here}
DISCORD_TOKEN= {your Discord bot token here}
PUBLIC_KEY= {your Discord application public key here}

# Server address and guild ID for the bot to operate in.
SERVER_ADDRESS= {your Palworld server address here, e.g., example.com:port}
GUILD_ID= {your Discord guild (server) ID here}